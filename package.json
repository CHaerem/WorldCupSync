{
  "name": "worldcupsync",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Spoiler-free 2026 FIFA World Cup replay planner for Norway (NRK / TV2)",
  "scripts": {
    "build": "node scripts/build.js",
    "fetch:matches": "node scripts/fetch-matches.js",
    "fetch:standings": "node scripts/fetch-standings.js",
    "fetch:streams": "node scripts/fetch-streams.js",
    "fetch:stats": "node scripts/fetch-stats.js",
    "dev": "python3 -m http.server 8000 --directory docs"
  },
  "engines": {
    "node": ">=18"
  }
}
